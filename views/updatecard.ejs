<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>admin</title>
     <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <style>
        body{
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
    </style>
</head>
<body>
    <form action="/admin/updatecard" class="col-12 col-md-8 col-lg-6 m-auto container p-3 shadow-lg rounded">

        <input type="hidden"  class="form-control" value="<%= editdata[0].cid %>"  name="cid">
        <div class="form-group mb-2">
            <label for="" class="form-label">Title of movie</label>
            <input type="text" class="form-control" value="<%= editdata[0].title %>"  name="title">
        </div>
        <div class="form-group mb-2">
            <label for="" class="form-label">Image</label>
            <input type="text" class="form-control" name="image" value="<%= editdata[0].image %>">
        </div>
        <div class="form-group mb-2">
            <label for="" class="form-label">Year of release</label>
            <input type="text" class="form-control" name="year" value="<%= editdata[0].year %>">
        </div>
        <div class="form-group mb-2">
            <label for="" class="form-label">Director</label>
            <input type="text" class="form-control" name="director" value="<%= editdata[0].director %>">
        </div>
        <div class="form-group mb-2">
            <label for="" class="form-label">Genre</label>
            <input type="text" class="form-control" name="genre" value="<%= editdata[0].genre %>">
        </div>
        <div class="form-group mb-2">
            <label for="" class="form-label">description</label>
            <input type="text" class="form-control" name="description" value="<%= editdata[0].description %>">
        </div>
          <div class="form-group mb-2">
            <label for="" class="form-label">Trailer URL</label>
            <input type="text" class="form-control" name="trailer" value="<%= editdata[0].trailer %>">
        </div>
       
        <button class="btn btn-primary w-100" type="submit">Update Card</button>
    </form>
</body>
</html>