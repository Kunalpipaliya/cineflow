<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineFlow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>

<body class="bg-dark">
    <span class="d-flex justify-content-center mt-4 fs-1 fw-bold"><span class="text-white">Cine</span><span
            class="text-warning">Flow</span></span>
    <p class="text-center text-warning">Discovery Portal</p>

    <div class="container">
        <div class="row g-3">
            <% data.map((item,index)=>{
                %>
                <div class="col-12 col-lg-6">
                    <div class="p-2 rounded-3" style="background-color: #334456;">
                        <div class="row">
                            <div class="col-4">
                                <img src="<%= item.image %>" class="rounded" width="100%">
                            </div>
                            <div class="col-8 d-flex flex-column justify-content-evenly">
                                <h3 class="text-white">
                                    <%= item.title %>
                                </h3>
                                <div class="d-flex flex-wrap gap-2">
                                    <% for(let i=0; i<item.genre.split(",").length; i++){ %>
                                        <span class="rounded-pill bg-secondary px-2 text-white">

                                            <%= item.genre.split(",")[i]%>
                                        </span>
                                        <% } %>
                                </div>
                                <strong class="text-white">Year: <%= item.year %> | Director: <%= item.director %>
                                </strong>
                                <div class="d-flex gap-3 align-items-center">
                                    <a class="px-3 btn btn-danger rounded" href="/detail/<%= item.cid %>">Details</a>
                                    <button class="px-3 btn btn-secondary rounded">Watch Trailer</button>
                                    <i class="px-3 text-secondary fs-5 fa-solid fa-share-nodes"></i>
                                    <i class="px-3 text-secondary fs-5 fa-regular fa-heart"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>
</body>

</html>