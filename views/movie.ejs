<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>

<body class="bg-dark">
    <span class="d-flex justify-content-center mt-4 fs-1 fw-bold"><span class="text-white">Cine</span><span
            class="text-warning">Flow</span></span>
    <p class="text-center text-warning">Discovery Portal</p>
    <div class="container">
        <a href="/" class="text-white text-decoration-none "><i class="fa-solid fa-arrow-left"></i> back</a>
        <% data.map((item,index)=>{
            %>
            <div class="row g-3">
                <div class="col-12 col-md-8 col-lg-4 ">

                    <img src="<%= item.image %>" alt="" height="500px" width="100%" class="rounded">
                </div>
                <div class="col-12 col-md-12 col-lg-8 p-5 d-flex flex-column gap-4" style="background-color: #334456;">

                    <h1 class="text-white" style="font-size: 50px; font-weight: 900;">
                        <%= item.title %>
                    </h1>
                    <div class="d-flex align-items-center gap-2">

                        <strong class="text-white">Director : </strong><span class="text-white"><%= item.director %></span>
                    </div>
                    <div class="d-flex align-items-center gap-2">

                        <strong class="text-white">Released : </strong><span class="text-white"><%= item.year %></span>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <strong class="text-white">Genre : </strong>
                        <% for(let i=0; i<item.genre.split(",").length; i++){ %>
                            <span class="rounded-pill bg-secondary px-2 text-white">

                                <%= item.genre.split(",")[i]%>
                            </span>
                            <% } %>
                    </div>
                    <div class="text-white">
                        <h1>Description</h1>
                        <p><%= item.description %></p>
                    </div>
                    
                </div>

            </div>

            <% }) %>
    </div>
</body>

</html>